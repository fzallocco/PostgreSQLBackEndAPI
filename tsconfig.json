{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "sourceMap": true,        // Required for browser/IDE debugging
    "outDir": "./dist",       // Keeps .js and .map files separate from .ts
    "rootDir": "./src"        // Ensures source structure is mirrored in dist
  },
  "include": ["src/**/*"]
}
